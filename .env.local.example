# ║  VillaOS v7 — .env.local                                    ║
# ║  Copy file này, điền giá trị thật từ Supabase Dashboard     ║
# ║  ⚠️  KHÔNG commit file này lên git                           ║
# ╚══════════════════════════════════════════════════════════════╝

# ── Supabase ──────────────────────────────────────────────────────
# Lấy tại: https://supabase.com/dashboard → Project → Settings → API

# Public (safe to expose to browser)
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGc...

# ⚠️  SERVICE ROLE KEY — KHÔNG BAO GIỜ EXPOSE RA BROWSER
# Chỉ dùng trong Server Actions / Route Handlers
# (adminCreateUserAction, seed.ts)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGc...

# ── App ───────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Production: NEXT_PUBLIC_APP_URL=https://villaos.vn

# ── Supabase Email (nếu dùng custom SMTP) ────────────────────────
# Cấu hình tại: Supabase Dashboard → Authentication → Email Templates
